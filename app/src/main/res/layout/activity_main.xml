<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:id="@+id/main_layout_container">

    <EditText
        android:id="@+id/et_surface_m2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Surface habitable (m²)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/et_nombre_pieces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de pièces"
        android:inputType="number" />

    <CheckBox
        android:id="@+id/cb_option_piscine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Présence d'une piscine" />

    <Button
        android:id="@+id/btn_lancer_calcul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculer la Taxe"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_affichage_resultat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />
</LinearLayout>